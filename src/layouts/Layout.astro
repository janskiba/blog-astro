---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="supported-color-schemes" content="dark" />
    <meta name="theme-color" content="#182232" />
    <meta
      name="description"
      content="Personal blog about frontend development, Angular, TypeScript and web engineering."
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>janskiba.dev</title>
  </head>
  <body
    class="min-h-screen flex flex-col w-full bg-linear-to-br from-gray-900 via-gray-800 to-gray-900"
  >
    <Header />
    <main class="flex-1 mx-auto max-w-5xl w-full">
      <slot />
    </main>
    <Footer />
  </body>
</html>
